# Database (PostgreSQL or SQLite)
# Use Supabase connection string for production
DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require
# Or use SQLite for local dev:
# DATABASE_URL=sqlite:///instance/anime_embeds.db

# Redis (required for RQ tasks and caching)
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=change-me-to-a-random-string
API_KEY=6767

# Flask
FLASK_APP=run.py
FLASK_DEBUG=false

# Scraper
HEADLESS=true
BROWSER_TIMEOUT=15000

# Cache
CACHE_TYPE=flask_caching.backends.simplecache.SimpleCache
CACHE_REDIS_URL=redis://localhost:6379
CACHE_DEFAULT_TIMEOUT=300
SEARCH_CACHE_TTL_SECONDS=120
CATALOG_CACHE_TTL_SECONDS=120
HOME_FEATURED_CACHE_TTL_SECONDS=1800
EMBED_CACHE_TTL_HOURS=24
EMBED_CACHE_CLEANUP_INTERVAL_SECONDS=3600

# Database pool
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

# Rate limiting
RATELIMIT_STORAGE_URI=memory://

# Pagination
SEARCH_LIMIT=50
DEFAULT_PAGE_SIZE=30
MAX_PAGE_SIZE=100

# CORS (comma-separated origins or "*")
CORS_ORIGINS=*

# Domain
CURRENT_DOMAIN=animesdigital.org

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/opt/render/project/.render/ms-playwright
PYTHON_VERSION=3.11.9
RENDER=true
