# Flask settings
SECRET_KEY=sua_chave_secreta_aqui
FLASK_DEBUG=false
PORT=5000

# API Settings
API_KEY=troque_para_uma_chave_forte

# Database (SQLite local por padrão quando vazio)
# Exemplo Supabase: postgresql://postgres:<senha>@<host>:5432/postgres
DATABASE_URL=
DB_CONNECT_TIMEOUT=10
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Cache/Rate Limit
CACHE_TYPE=flask_caching.backends.simplecache.SimpleCache
CACHE_DEFAULT_TIMEOUT=300
RATELIMIT_STORAGE_URI=memory://
SEARCH_CACHE_TTL_SECONDS=120
HOME_FEATURED_CACHE_TTL_SECONDS=180
EMBED_CACHE_TTL_HOURS=24
EMBED_CACHE_CLEANUP_INTERVAL_SECONDS=3600
EMBED_CACHE_CLEANUP_BATCH_SIZE=1000
SEARCH_LIMIT=50
DEFAULT_PAGE_SIZE=30
MAX_PAGE_SIZE=100

# Scraper Settings
HEADLESS=true
BROWSER_TIMEOUT=60000

# Cataloguer script
CATALOGUER_API_BASE_URL=http://localhost:5000/get-embed
CATALOGUER_REQUEST_DELAY_SECONDS=1.2
CATALOGUER_MAX_RETRIES=4
CATALOGUER_BACKOFF_BASE_SECONDS=1.5
CATALOGUER_TIMEOUT_SECONDS=60
