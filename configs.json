{
  "animesdigital": {
    "domain": "animesdigital.org",
    "url_patterns": {
      "home": "^https?://animesdigital\\.org/home/?$",
      "anime_main": "^https?://animesdigital\\.org/anime/.+",
      "episode": "^https?://animesdigital\\.org/video/.+",
      "movie": "^https?://animesdigital\\.org/filme/.+"
    },
    "selectors": {
      "home": {
        "episodes_section": ".itemE a, .itemA a",
        "item_info_selector": ".number",
        "home_sections": {
          "releases": "LANÇAMENTOS",
          "episodes": "ÚLTIMOS EPISÓDIOS",
          "animes": "ÚLTIMOS ANIMES",
          "movies": "ÚLTIMOS FILMES"
        }
      },
      "anime_main": {
        "title": "h1",
        "episodes_section": "a[href*='video/']",
        "pagination": "ul.content-pagination li a"
      },
      "episode": {
        "title": "h1",
        "iframe_selectors": [
          "#player1 iframe",
          "#player iframe",
          ".tab-video iframe"
        ]
      },
      "directory": {
        "url_pattern": "^https?://animesdigital\\.org/animes-legendados-online.*$",
        "item_selector": "div.itemA a",
        "pagination_info": "div.m_center > p.infos-list"
      }
    },
    "bypass_javascript": false
  }
}
